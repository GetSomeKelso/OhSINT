# OhSINT — API Key Configuration
# Copy this file to api_keys.yaml and fill in your keys.
# NEVER commit api_keys.yaml to version control.

mcp_server:
  # Bearer token for MCP SSE authentication (MCP07)
  # Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
  # Also settable via OHSINT_MCP_TOKEN env var
  bearer_token: ""

shodan:
  api_key: ""

virustotal:
  # https://www.virustotal.com/gui/my-apikey — free tier: 4 req/min, 500/day
  api_key: ""

brave:
  api_key: ""  # https://brave.com/search/api/ — free tier: 2,000 queries/month

theharvester:
  github_token: ""
  hunter_api: ""
  intelx_api: ""
  securitytrails_api: ""

spiderfoot:
  virustotal: ""
  censys_id: ""
  censys_secret: ""
  fullcontact: ""
  hunter: ""
  ipinfo: ""

recon_ng:
  builtwith_api: ""
  github_api: ""
  google_api: ""
  hashes_api: ""
  ipinfodb_api: ""
  shodan_api: ""
  virustotal_api: ""
  whoxy_api: ""

github_dorks:
  github_token: ""

linkedin:
  # Required for linkedin2username (active recon only)
  # Use a dedicated research account, NOT your personal LinkedIn
  email: ""
  password: ""

hunter_io:
  # Optional — improves InSpy email verification
  api_key: ""

# ── Phone & Identity — Tier 1 (Open API) ──

numverify:
  # https://numverify.com/ — free: 100 req/month
  api_key: ""

twilio:
  # https://console.twilio.com/ — ~$0.005 per lookup
  account_sid: ""
  auth_token: ""

censys:
  # https://search.censys.io/account/api — free: 250 req/month
  api_id: ""
  api_secret: ""

# ── Phone & Identity — Tier 2 (Threat Intel) ──

intelx:
  # https://intelx.io/account?tab=developer — free tier available
  api_key: ""

hudson_rock:
  # https://www.hudsonrock.com/ — free basic tier, optional Pro key
  api_key: ""

spycloud:
  # Enterprise only — requires security firm verification
  # Set enabled: true when you have an active SpyCloud account
  enabled: false
  api_key: ""
  api_endpoint: ""

# ── Phone & Identity — Tier 3 (Commercial, FCRA-gated) ──

whitepages_pro:
  # https://pro.whitepages.com — requires subscription + FCRA purpose
  api_key: ""

beenverified:
  # https://www.beenverified.com/business/ — requires business subscription + FCRA purpose
  api_key: ""
  api_endpoint: ""

